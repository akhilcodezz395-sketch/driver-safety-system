<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A202C">

    <!-- Top Dark Overlay Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dark_overlay"
        android:layout_margin="16dp"
        android:padding="20dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ Settings"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E5E7EB" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/infoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Settings info"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- Haptic Feedback Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Haptic Feedback"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enable vibration alerts"
                        android:textSize="13sp"
                        android:textColor="#9CA3AF" />

                    <Switch
                        android:id="@+id/hapticSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Vehicle Type Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Type"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/vehicleTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioCar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗 Car (Standard)"
                        android:textColor="#D1D5DB"
                        android:buttonTint="#4CAF50"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioBike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏍️ Motorcycle (High Sensitivity)"
                        android:textColor="#D1D5DB"
                        android:buttonTint="#FF9800" />

                    <RadioButton
                        android:id="@+id/radioTruck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚚 Truck (Early Warning)"
                        android:textColor="#D1D5DB"
                        android:buttonTint="#F44336" />
                </RadioGroup>
            </LinearLayout>

            <!-- Data Upload Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Upload Consent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Cloud feature - not implemented)"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Allow anonymous telemetry"
                        android:textSize="13sp"
                        android:textColor="#9CA3AF" />

                    <Switch
                        android:id="@+id/uploadConsentSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
