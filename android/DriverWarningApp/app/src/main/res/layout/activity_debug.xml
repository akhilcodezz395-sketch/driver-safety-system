<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A202C">

    <!-- Top Dark Overlay Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dark_overlay"
        android:layout_margin="16dp"
        android:padding="20dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 Debug Testing"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E5E7EB" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Input Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feature Values (JSON)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/featureInput"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#E5E7EB"
                    android:background="#374151"
                    android:padding="12dp" />
            </LinearLayout>

            <Button
                android:id="@+id/runInferenceButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="▶ RUN INFERENCE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/button_rectangle"
                android:textColor="#FFFFFF"
                android:elevation="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Vibration Test Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Training Data Export"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/logPathText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No logs found"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/exportLogButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📤 Export Last Log"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Vibration Test Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test Vibration Patterns"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/testMildButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mild Alert (3 pulses)"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/testUrgentButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Urgent Alert (4 pulses)"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/testHecticButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hectic Alert (2s continuous)"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Results Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dark_overlay"
                android:padding="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Results"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E5E7EB"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Run inference to see results"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:background="#374151"
                    android:padding="12dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
